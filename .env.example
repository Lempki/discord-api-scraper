# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required
DISCORD_API_SECRET=changeme

# Optional (defaults shown)

# Log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# LOG_LEVEL=INFO

# Maximum items to scrape per job.
# SCRAPER_MAX_ITEMS=100

# Time-to-live for job results (seconds).
# SCRAPER_JOB_TTL=3600

# User-Agent string sent with scrape requests.
# SCRAPER_USER_AGENT=discord-api-scraper/1.0
